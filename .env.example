# Supabase - client-safe (shipped to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Supabase - server-only (NEVER prefix with NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# OCR provider (set inside the Edge Function's secrets, not here)
# supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
# OCR_PROVIDER can be: "anthropic" | "google" | "textract"  — default anthropic
# Set in Edge Function secrets, see /supabase/functions/ocr-extract/README.md

# Optional: public app URL for OAuth redirects and email links
NEXT_PUBLIC_APP_URL=http://localhost:3000
